{
  "name": "kairo-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:worker": "wrangler dev worker/index.ts --local",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply kairo-local --local",
    "db:migrate:remote": "wrangler d1 migrations apply kairo-prod --remote --env production",
    "db:seed:remote": "wrangler d1 execute kairo-prod --remote --env production --file=worker/db/seed.sql",
    "content:beta:sql": "node scripts/generate-beta-import-sql.mjs content/beta-import.example.json content/beta-import.generated.sql",
    "deploy:worker": "wrangler deploy --env production",
    "db:seed:local": "wrangler d1 execute kairo-local --local --file=worker/db/seed.sql",
    "verify:copy": "node scripts/verify-runtime-copy.mjs",
    "verify:production": "node scripts/verify-production-readiness.mjs",
    "verify:routes": "node scripts/verify-api-routes.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "hono": "^4.12.27",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.105.0"
  }
}
